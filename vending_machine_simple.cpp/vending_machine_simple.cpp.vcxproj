#include <iostream>
#include <string>
#include <limits>
#include <ctime>
#include <cstdlib>
#include <stdexcept>

using namespace std;

// Свой класс исключения для автомата
class MachineError : public exception {
private:
    string msg;
public:
    MachineError(const string& m) : msg(m) {}
    const char* what() const noexcept override {
        return msg.c_str();
    }
};

// Структура напитка
struct Drink {
    string name;
    double price;
};

// Класс автомата
class VendingMachine {
private:
    Drink drinks[3];
    double balance;
    
public:
    VendingMachine() : balance(0) {
        drinks[0] = {"Кола", 50};
        drinks[1] = {"Фанта", 45};
        drinks[2] = {"Спрайт", 55};
    }
    
    void addMoney(double sum) {
        if (sum < 0) {
            throw invalid_argument("Сумма не может быть меньше 0");
        }
        balance = sum;
        cout << "Внесено: " << balance << " руб.\n";
    }
    
    void buy(int num) {
        // Поломка с вероятностью 20%
        if (rand() % 5 == 0) {
            throw MachineError("Автомат сломался!");
        }
        
        if (num < 1 || num > 3) {
            throw out_of_range("Нет такого напитка");
        }
        
        if (balance < drinks[num-1].price) {
            throw MachineError("Мало денег");
        }
        
        cout << "\nВы получили: " << drinks[num-1].name << endl;
        cout << "Сдача: " << balance - drinks[num-1].price << " руб.\n";
        balance -= drinks[num-1].price;
    }
    
    void showMenu() {
        cout << "\n--- МЕНЮ ---\n";
        for (int i = 0; i < 3; i++) {
            cout << i+1 << ". " << drinks[i].name 
                 << " - " << drinks[i].price << " руб.\n";
        }
        if (balance > 0) {
            cout << "Баланс: " << balance << " руб.\n";
        }
    }
    
    double getBalance() {
        return balance;
    }
};

// Ввод числа с проверкой
double inputNumber() {
    double x;
    cin >> x;
    
    if (cin.fail()) {
        cin.clear();
        cin.ignore(10000, '\n');
        throw invalid_argument("Ошибка: нужно вводить числа");
    }
    return x;
}

int main() {
    setlocale(LC_ALL, "Russian");
    srand(time(0));
    
    VendingMachine vm;
    double money;
    int choice;
    
    cout << "АВТОМАТ С ГАЗИРОВКОЙ\n";
    
    while (true) {
        try {
            // Ввод денег
            cout << "\nСколько денег внести? (0 - выход): ";
            money = inputNumber();
            
            if (money == 0) {
                cout << "До свидания!\n";
                break;
            }
            
            vm.addMoney(money);
            
            // Показ меню и выбор
            vm.showMenu();
            cout << "Выберите напиток (1-3): ";
            choice = (int)inputNumber();
            
            // Покупка
            vm.buy(choice);
            
        }
        catch (const out_of_range& e) {
            cout << "Ошибка: " << e.what() << endl;
        }
        catch (const MachineError& e) {
            cout << "Ошибка: " << e.what() << endl;
            if (string(e.what()) == "Автомат сломался!") {
                cout << "Вызвали мастера. Работаем дальше.\n";
            }
        }
        catch (const invalid_argument& e) {
            cout << "Ошибка: " << e.what() << endl;
        }
        catch (...) {
            cout << "Неизвестная ошибка!\n";
        }
    }
    
    return 0;
}
